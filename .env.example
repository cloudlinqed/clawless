# Required: AI provider and model
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o

# Required: API key for your provider
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Session store (optional, defaults to in-memory)
# SESSION_STORE=memory|upstash|vercel-kv

# Agent config
# MAX_TURNS=10
# TIMEOUT_MS=120000
# MAX_KNOWLEDGE_CHARS=100000

# CORS (set to your frontend URL in production)
# CORS_ORIGIN=https://yourdomain.com

# Data directory for persisted knowledge/secrets
# DATA_DIR=.clawless
