# Required: AI provider and model
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o
# DEFAULT_FALLBACK_MODELS=anthropic/claude-sonnet-4-5,gpt-4o-mini

# Runtime mode
# In production, auth is required by default and admin/config routes are closed.
# CLAWLESS_MODE=development

# API key for your chosen provider (set the one matching DEFAULT_PROVIDER)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# XAI_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=
# AZURE_OPENAI_API_KEY=
# CEREBRAS_API_KEY=

# Agent config
# MAX_TURNS=10
# TIMEOUT_MS=120000
# MAX_KNOWLEDGE_CHARS=100000

# CORS (set to your frontend URL in production)
# CORS_ORIGIN=https://yourdomain.com

# Authentication
# AUTH_REQUIRED=true
# AUTH_TRUSTED_USER_HEADER=x-user-id
# AUTH_JWT_SECRET=
# AUTH_JWKS_URL=
# AUTH_JWT_ISSUER=
# AUTH_JWT_AUDIENCE=
# AUTH_USER_ID_CLAIM=sub
# AUTH_ADMIN_ROLE_CLAIM=role
# AUTH_ADMIN_ROLE_VALUES=service_role,admin
# ADMIN_API_KEY=
# ADMIN_API_KEY_HEADER=x-clawless-admin-key

# Durable storage
# PERSISTENCE_DRIVER=postgres
# DATABASE_URL=postgresql://postgres:password@db.example.com:5432/postgres
# DATABASE_SSL=true
# DATABASE_TABLE_PREFIX=clawless

# Data directory for persisted knowledge/secrets/tools
# DATA_DIR=.clawless

# Optional: expose explicit env-backed tool secrets with a safe prefix only.
# Example: CLAWLESS_SECRET_STORE_API_KEY=...
# SECRET_ENV_PREFIX=CLAWLESS_SECRET_

# Optional: global host allowlist for builtin fetch_page/json_request
# Comma-separated exact hosts or wildcard suffixes, e.g. api.example.com,*.example.com
# OUTBOUND_ALLOWED_HOSTS=

# Optional: Vision, image generation, TTS
# VISION_PROVIDER=openai
# VISION_MODEL=gpt-4o
# IMAGE_MODEL=dall-e-3
# TTS_MODEL=tts-1

# Optional: Web search (enable web_search builtin after setting one)
# BRAVE_SEARCH_API_KEY=
# SERP_API_KEY=
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_CX=
